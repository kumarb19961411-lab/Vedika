rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Identity
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /vendors/{vendorId} {
      // Vendor Profile: Read by self, update heavily restricted to verified params.
      allow read: if request.auth != null && request.auth.uid == vendorId;
      allow update: if request.auth != null && request.auth.uid == vendorId 
                    && request.resource.data.keys().hasOnly(['businessName', 'primaryServiceCategory', 'imageUrl', 'location', 'capacity', 'pricing', 'amenities', 'ownerName', 'vendorType']);
      // Option B: Allow creation during explicit registration flow.
      allow create: if request.auth != null && request.auth.uid == vendorId;
    }

    // Bookings
    match /bookings/{bookingId} {
      // Vendors can read their own bookings.
      allow read: if request.auth != null && resource.data.vendorId == request.auth.uid;
      // Authoritative Transaction logic: Client writes if they own the vendor scope.
      allow create, update: if request.auth != null && request.resource.data.vendorId == request.auth.uid;
      allow delete: if false; // Financial audit transparency
    }

    // Blocked Dates
    match /blocked_dates/{blockId} {
      // Rule: allow if current user is the owner of the block.
      // Use resource.data for existing blocks, and request.resource.data for new ones.
      allow read: if request.auth != null && (resource == null || resource.data.vendorId == request.auth.uid);
      allow write: if request.auth != null && (request.resource == null || request.resource.data.vendorId == request.auth.uid);
    }

    // Inventory Catalog
    match /inventory/{itemId} {
      allow read: if request.auth != null && (resource == null || resource.data.vendorId == request.auth.uid);
      allow create, update: if request.auth != null && request.resource.data.vendorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.vendorId == request.auth.uid;
    }
  }
}
