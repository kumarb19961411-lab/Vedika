rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Identity
    match /vendors/{vendorId} {
      // Vendor Profile: Read by self, update heavily restricted to verified params.
      // Phone number omitted here since it's handled by Auth Provider natively mostly.
      allow read: if request.auth != null && request.auth.uid == vendorId;
      allow update: if request.auth != null && request.auth.uid == vendorId 
                    && request.resource.data.keys().hasOnly(['businessName', 'primaryServiceCategory', 'imageUrl']);
      allow create: if false; // Only a trusted Cloud Function can create verified Vendor Profiles.
    }

    // Bookings Base
    match /bookings/{bookingId} {
      // Bookings: Vendors can read their own bookings.
      allow read: if request.auth != null && resource.data.vendorId == request.auth.uid;
      // Staging Note (Phase 2): Create/Update is allowed locally for staging tests, but in PROD this is locked.
      // Final constraint: Bookings created/updated strictly by Trusted Backend (Cloud Function)
      allow create, update: if request.auth != null && request.resource.data.vendorId == request.auth.uid;
      allow delete: if false; // Financial audibility requires never deleting bookings
    }

    // Inventory Catalog
    match /inventory/{itemId} {
      // Inventory Items: Vendor manages their own catalog.
      allow read: if request.auth != null && resource.data.vendorId == request.auth.uid;
      allow create, update: if request.auth != null && request.resource.data.vendorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.vendorId == request.auth.uid;
    }
  }
}
